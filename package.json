{
  "name": "wordwise-correctify",
  "version": "1.0.0",
  "description": "AI-Powered Spelling & Grammar Corrector",
  "scripts": {
    "install:all": "npm install && cd client && npm install && cd ../server && npm install",
    "client": "cd client && npm run dev",
    "server": "cd server && npm start",
    "nlp": "cd nlp-service && .\\venv\\Scripts\\activate && python app.py",
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run nlp\"",
    "build": "cd client && npm run build",
    "start": "cd server && node server.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
